# Harvester Configuration
HARVESTER_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/harvester
HARVESTER_API_TOKEN=change-me-in-production
HARVESTER_ARCHIVE_PATH=/data/harvester/archive
HARVESTER_LOG_LEVEL=INFO
HARVESTER_API_URL=http://localhost:8001
HARVESTER_PORT=8001
HARVESTER_FRONTEND_PORT=5173

# Firecrawl Adapter
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_API_KEY=
FIRECRAWL_SCRAPE_PATH=/v1/scrape
FIRECRAWL_TIMEOUT=30
FIRECRAWL_MAX_BYTES=10485760

# Archive Settings
HARVESTER_MAX_PAYLOAD_BYTES=10485760
HARVESTER_RAW_RETENTION_DAYS=7

# Live Crawl Smoke (set to 1 to enable live network tests)
HARVESTER_ENABLE_LIVE_CRAWL=0

# CDC Live Smoke (set to 1 to enable CDC live network tests)
HARVESTER_CDC_LIVE_SMOKE=0

# Live Qwen Embedding (set to 1 to enable live Qwen embedding integration tests)
HARVESTER_LIVE_QWEN_EMBEDDING=0

# Embedding Adapter Configuration
# Adapter type: stub (deterministic, offline) or qwen (OpenAI-compatible HTTP)
HARVESTER_EMBEDDING_ADAPTER=stub
# Model identifier written into chunk.embedding_model
HARVESTER_EMBEDDING_MODEL=stub-embedding-1536
# Expected embedding dimension (must match pgvector column)
HARVESTER_EMBEDDING_DIMENSION=1536

# Qwen Embedding Service (required when HARVESTER_EMBEDDING_ADAPTER=qwen)
HARVESTER_QWEN_EMBEDDING_BASE_URL=http://localhost:8080
HARVESTER_QWEN_EMBEDDING_TIMEOUT_SECONDS=30

# Scheduler Daemon Configuration
# Set to 1 to enable scheduler and crawl worker daemons in ./start.sh
HARVESTER_START_DAEMONS=0

# Scheduler daemon poll interval in seconds
HARVESTER_SCHEDULER_POLL_INTERVAL=30

# Scheduler daemon max schedules per iteration
HARVESTER_SCHEDULER_LIMIT=100

# Crawl worker daemon poll interval in seconds
HARVESTER_CRAWL_WORKER_POLL_INTERVAL=10

# Crawl worker daemon max jobs per iteration
HARVESTER_CRAWL_WORKER_LIMIT=10

# Audit Log Retention
# Audit events older than this many days are automatically deleted by the scheduler daemon
HARVESTER_AUDIT_RETENTION_DAYS=7
# Minimum hours between automatic audit cleanup runs (default: 24)
HARVESTER_AUDIT_CLEANUP_INTERVAL_HOURS=24

# Skip DNS-based IP check in fetch policy (useful behind proxy/VPN)
# When set to "1", all URL targets are allowed regardless of resolved IP address.
# Intended for development/home-lab use behind a trusted proxy (e.g. Surge/ClashX
# in Fake-IP mode) where DNS returns RFC 2544 addresses that Python marks as private.
# HARVESTER_FETCH_POLICY_SKIP_DNS=1
